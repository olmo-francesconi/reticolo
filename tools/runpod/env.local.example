# Copy to env.local (gitignored) and fill in your pod's SSH details.
# From RunPod's "ssh root@<ip> -p <port> -i <key>" line:
export RUNPOD_HOST=<pod-ip>
export RUNPOD_PORT=<pod-ssh-port>
export RUNPOD_KEY=$HOME/.ssh/runpod
export RUNPOD_ARCH=70          # V100=70, A100=80, H100=90
# export RUNPOD_DIR=/root/reticolo   # remote source dir (default)
